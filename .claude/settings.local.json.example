{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "excludedCommands": ["docker *", "gh *", "npm *", "pnpm *", "task *"]
  },
  "permissions": {
    "allow": [
      "Bash(npm run test:*)",
      "Bash(npm run build:*)",
      "Bash(pnpm test:*)",
      "Bash(task test:*)"
    ]
  }
}
