{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "cleanupPeriodDays": 9999,
  "sandbox": {
    "enabled": true,
    "excludedCommands": ["docker *", "gh *"]
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git revert:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf /*:*)",
      "Bash(sudo:*)",
      "Bash(chmod -R 777:*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.netrc)",
      "Read(~/.git-credentials)",
      "Read(//etc/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.json)"
    ]
  }
}
