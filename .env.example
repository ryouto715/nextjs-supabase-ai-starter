# Supabase Local（npx supabase start 起動後の表示を貼り付け）
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<supabase start 実行時に表示される anon key>"

# サーバー専用（絶対に NEXT_PUBLIC_ を付けないこと）
SUPABASE_SERVICE_ROLE_KEY="<supabase start 実行時に表示される service_role key>"

# Drizzle（Supabase Local の DB 接続文字列）
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
